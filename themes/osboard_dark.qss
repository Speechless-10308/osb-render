/* ============================================================
   OSBoard — Dark Theme (Dracula-based)
   ============================================================ */

/* === GLOBAL === */
* {
    font-family: "Segoe UI", "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 13px;
    color: #f8f8f2;
}

/* === FRAMELESS WINDOW BACKGROUND === */
QMainWindow {
    background-color: transparent;
}

#bgApp {
    background-color: #1a1b26;
    border: 1px solid #1e1f2b;
    border-radius: 10px;
}

/* === TITLE BAR === */
QFrame#titleBar {
    background-color: #1a1b26;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

QLabel#titleBarLabel {
    font-size: 13px;
    font-weight: 600;
    color: #f8f8f2;
    padding-left: 4px;
}

QPushButton#titleBarBtn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px;
}
QPushButton#titleBarBtn:hover {
    background-color: #282a36;
}
QPushButton#titleBarBtn:pressed {
    background-color: #343746;
}

QPushButton#titleBarCloseBtn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px;
}
QPushButton#titleBarCloseBtn:hover {
    background-color: #ff5555;
}

/* === ALL INPUTS === */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #343746;
    border: 1px solid #44475a;
    border-radius: 8px;
    padding: 6px 10px;
    color: #f8f8f2;
    selection-background-color: #ff66aa;
    selection-color: #f8f8f2;
}
QLineEdit:focus, QSpinBox:focus, QComboBox:focus {
    border: 1px solid #ff66aa;
}

QComboBox:on {
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border-left: 1px solid #44475a;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
}
QComboBox QAbstractItemView {
    background-color: #282a36;
    border: none;
    outline: 0px;
    border-radius: 0px;
    padding: 0px;
    margin: 0px;
    selection-background-color: #44475a;
    color: #f8f8f2;
}
QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    border: none;
    min-height: 20px;
}
QComboBox QAbstractItemView::item:selected {
    background-color: #44475a;
    border: none;
}

QSpinBox::up-button, QSpinBox::down-button {
    border: none;
    background: transparent;
    width: 16px;
}

/* === CHECKBOX === */
QCheckBox {
    spacing: 8px;
    color: #f8f8f2;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #44475a;
    border-radius: 4px;
    background-color: #343746;
}
QCheckBox::indicator:checked {
    background-color: #ff66aa;
    border-color: #ff66aa;
}

/* === PUSH BUTTON BASE === */
QPushButton {
    background-color: #44475a;
    color: #f8f8f2;
    border: none;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 600;
}
QPushButton:hover {
    background-color: #6272a4;
}
QPushButton:pressed {
    background-color: #343746;
}
QPushButton:disabled {
    background-color: #2a2b36;
    color: #6272a4;
}

/* === SCROLLBARS === */
QScrollBar:vertical {
    background: #1a1b26;
    width: 8px;
    margin: 0;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #44475a;
    min-height: 30px;
    border-radius: 4px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal {
    background: #1a1b26;
    height: 8px;
    margin: 0;
    border-radius: 4px;
}
QScrollBar::handle:horizontal {
    background: #44475a;
    min-width: 30px;
    border-radius: 4px;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* === SCROLL AREA === */
QScrollArea {
    background-color: transparent;
    border: none;
}
QScrollArea > QWidget > QWidget {
    background-color: #1a1b26;
}
QScrollArea#settingsScroll > QWidget > QWidget#settingsInner {
    background-color: #1a1b26;
}
QScrollArea#homeScroll > QWidget > QWidget#homeInner {
    background-color: transparent;
}

/* === PROGRESS BAR === */
QProgressBar {
    background-color: #343746;
    border: 1px solid #44475a;
    border-radius: 8px;
    text-align: center;
    color: #f8f8f2;
    font-weight: bold;
    height: 22px;
}
QProgressBar::chunk {
    background-color: #ff66aa;
    border-radius: 7px;
}

/* === TOOLTIP === */
QToolTip {
    background-color: #282a36;
    color: #f8f8f2;
    border: 1px solid #44475a;
    border-radius: 4px;
    padding: 4px 8px;
}

/* === DIALOG === */
QDialog { background-color: #1a1b26; }
QDialogButtonBox QPushButton { min-width: 80px; }
QMessageBox { background-color: #1a1b26; }
QMessageBox QLabel { color: #f8f8f2; }
QMessageBox QPushButton { min-width: 80px; }

/* ============================================================
   NAMED OBJECT SELECTORS
   ============================================================ */

/* === SIDEBAR === */
QFrame#sidebarFrame {
    background-color: #1a1b26;
    border-right: 1px solid #1e1f2b;
}

QPushButton#sidebarBtn {
    background: transparent;
    color: #6272a4;
    border: none;
    border-radius: 0;
    border-left: 3px solid transparent;
    padding: 12px 20px;
    text-align: left;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#sidebarBtn:hover {
    background-color: #282a36;
    color: #f8f8f2;
}
QPushButton#sidebarBtn:checked {
    background-color: #282a36;
    color: #ff66aa;
    border-left: 3px solid #ff66aa;
}

QLabel#sidebarIcon {
    min-width: 40px;
    min-height: 40px;
}

QLabel#sidebarBrand {
    font-size: 16px;
    font-weight: bold;
    color: #ff66aa;
}

/* Collapsed sidebar state */
QFrame#sidebarFrame[collapsed="true"] QPushButton#sidebarBtn {
    padding: 12px 20px;
    font-size: 0px;
}
QFrame#sidebarFrame[collapsed="true"] QLabel#sidebarBrand {
    font-size: 0px;
    padding: 0;
    margin: 0;
}

/* === CARDS === */
QFrame#card {
    background-color: #282a36;
    border: 1px solid #2d2f3d;
    border-radius: 8px;
}

QFrame#settingGroup {
    background-color: transparent;
    border: 1px solid #2d2f3d;
    border-radius: 6px;
}

QLabel#cardTitle {
    font-size: 15px;
    font-weight: bold;
    color: #bd93f9;
}

QLabel#cardIcon {
    min-width: 24px;
    min-height: 24px;
}

/* === ACTION BUTTONS === */
QPushButton#primaryBtn {
    background-color: #ff66aa;
    color: #f8f8f2;
    border: none;
    border-radius: 8px;
    padding: 12px 32px;
    font-size: 15px;
    font-weight: bold;
    min-height: 44px;
}
QPushButton#primaryBtn:hover { background-color: #ff85bb; }
QPushButton#primaryBtn:pressed { background-color: #d94d8a; }
QPushButton#primaryBtn:disabled {
    background-color: #3d2a3a;
    color: #6272a4;
}

QPushButton#secondaryBtn {
    background-color: transparent;
    color: #ff5555;
    border: 1px solid #ff5555;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 600;
    min-height: 44px;
}
QPushButton#secondaryBtn:hover { background-color: #3d1f1f; }
QPushButton#secondaryBtn:pressed {
    background-color: #ff5555;
    color: #f8f8f2;
}
QPushButton#secondaryBtn:disabled {
    background-color: transparent;
    border-color: #44475a;
    color: #6272a4;
}

/* === BROWSE BUTTONS === */
QPushButton#browseBtn {
    background-color: #343746;
    color: #f8f8f2;
    border: 1px solid #44475a;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
}
QPushButton#browseBtn:hover {
    background-color: #44475a;
    border-color: #6272a4;
}

/* === FILE PATH INPUT === */
QLineEdit#filePathInput {
    background-color: #343746;
    border: 1px solid #44475a;
    border-radius: 8px;
    padding: 8px 10px;
    color: #8be9fd;
    font-size: 13px;
}
QLineEdit#filePathInput:focus { border-color: #ff66aa; }

/* === CONSOLE OUTPUT === */
QTextEdit#consoleOutput {
    background-color: #1a1b26;
    border: 1px solid #2d2f3d;
    border-radius: 8px;
    padding: 10px;
    color: #f8f8f2;
    font-family: "Consolas", "Cascadia Code", "Fira Code", "JetBrains Mono", monospace;
    font-size: 12px;
    selection-background-color: #44475a;
}

/* === RESOLUTION SPINBOXES === */
QSpinBox#resSpinBox {
    min-width: 90px;
    font-size: 14px;
    font-weight: 500;
}

/* === ASPECT RATIO LOCK === */
QPushButton#linkBtn {
    color: #6272a4;
    font-size: 10px;
    border-radius: 4px;
    padding: 2px;
    border: none;
    background: transparent;
}
QPushButton#linkBtn:hover {
    background-color: #343746;
    color: #f8f8f2;
}
QPushButton#linkBtn:checked {
    background-color: #ff66aa;
    color: #f8f8f2;
}

/* === PAGE TITLE === */
QLabel#pageTitle {
    font-size: 22px;
    font-weight: bold;
    color: #f8f8f2;
    padding-bottom: 4px;
}

/* === SETTINGS-SPECIFIC === */
QSpinBox#crfSpin { min-width: 80px; }

/* === ABOUT === */
QLabel#aboutDescription {
    color: #6272a4;
    font-size: 13px;
}

/* === GROUP HEADER (grid section labels) === */
QLabel#groupHeader {
    color: #bd93f9;
    font-size: 12px;
    font-weight: bold;
    padding-top: 4px;
}

/* === HELPER LABELS === */
QLabel#mutedLabel {
    color: #6272a4;
    font-size: 12px;
}
QLabel#pathLabel {
    color: #8be9fd;
    font-size: 12px;
}
